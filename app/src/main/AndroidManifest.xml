<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Exact alarm scheduling: API 31-33 runtime permission (USE_EXACT_ALARM covers 33+, SCHEDULE_EXACT_ALARM is the fallback for 31-32).
         USE_EXACT_ALARM is the "exempt" path for alarm/reminder apps; no UI flow to settings.
         SCHEDULE_EXACT_ALARM may be denied by the user on 31-32; denial handling is #48's scope. -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- Required to receive ACTION_BOOT_COMPLETED for alarm restoration (AC-NT-9). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="false"
        android:enableOnBackInvokedCallback="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:networkSecurityConfig="@xml/network_security_config"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:windowSoftInputMode="adjustResize"
        android:theme="@style/Theme.DateCountdown">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- AlarmReceiver: placeholder for issue #45. exported=false — only this app can trigger it (AC-NT-9).
             No intent-filter; AlarmManager targets it via explicit ComponentName. -->
        <receiver
            android:name=".notifications.AlarmReceiver"
            android:exported="false" />

        <!-- BootReceiver: reschedules all upcoming event alarms after device reboot (AC-NT-9/10).
             exported=true — the system must be able to deliver ACTION_BOOT_COMPLETED.
             android:permission restricts delivery to the system only (defense-in-depth).
             Intent action is also validated inside onReceive. -->
        <receiver
            android:name=".notifications.BootReceiver"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
          <intent-filter>
            <action android:name="android.intent.action.BOOT_COMPLETED" />
          </intent-filter>
        </receiver>
    </application>

</manifest>
