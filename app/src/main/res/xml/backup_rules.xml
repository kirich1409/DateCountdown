<?xml version="1.0" encoding="utf-8"?>
<!--
  Auto-backup rules for API < 31 (android:fullBackupContent).
  On API 31+ this file is superseded by data_extraction_rules.xml.
  See https://developer.android.com/guide/topics/data/autobackup

  AC-DM-12: Room database (events.db) is excluded — it stores user event data
  that must not leave the device.
  DataStore preferences are excluded — they hold user settings (theme, sort order).
-->
<full-backup-content>
  <!-- Room database — user events (AC-DM-12) -->
  <exclude domain="database" path="events.db" />
  <!-- DataStore preferences — user settings (AC-DM-12) -->
  <exclude domain="sharedpref" path="." />
</full-backup-content>
