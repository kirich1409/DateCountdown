<?xml version="1.0" encoding="utf-8"?>
<!--
  Data extraction rules for API 31+ (android:dataExtractionRules).
  Applies to both cloud backup and device-to-device transfer.
  See https://developer.android.com/about/versions/12/backup-restore#xml-changes

  AC-DM-12: Room database (events.db) and DataStore preferences are excluded
  from both cloud backup and device transfer — user event data and settings
  must not leave the device.
-->
<data-extraction-rules>
  <cloud-backup>
    <!-- Room database — user events (AC-DM-12) -->
    <exclude domain="database" path="events.db" />
    <!-- DataStore preferences — user settings (AC-DM-12) -->
    <exclude domain="sharedpref" path="." />
  </cloud-backup>
  <device-transfer>
    <!-- Room database — user events (AC-DM-12) -->
    <exclude domain="database" path="events.db" />
    <!-- DataStore preferences — user settings (AC-DM-12) -->
    <exclude domain="sharedpref" path="." />
  </device-transfer>
</data-extraction-rules>
