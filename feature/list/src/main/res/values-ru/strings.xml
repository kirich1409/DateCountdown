  <string name="list_past_section_history_description">История</string>
  <!-- "Прошедшие · N" — разделитель U+00B7 -->
  <string name="list_past_section_title">Прошедшие · %d</string>
  <string name="list_past_collapse">Свернуть</string>
  <string name="list_past_expand">Развернуть</string>
