  <!-- Global empty state -->
  <string name="list_empty_heading">Создайте первое событие</string>
  <string name="list_empty_body">Добавьте дату, которую ждёте — приложение посчитает остаток до секунды.</string>
  <string name="list_empty_icon_description">Песочные часы</string>

