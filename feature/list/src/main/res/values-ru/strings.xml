  <string name="list_partial_empty_heading">Нет предстоящих событий</string>
  <string name="list_partial_empty_body">Добавьте новое событие, чтобы начать обратный отсчёт.</string>

  <!-- Error state -->
  <string name="list_error_message">Не удалось загрузить события. Попробуйте ещё раз.</string>

  <!-- FAB -->
  <string name="list_fab_label">Новое событие</string>
  <string name="list_fab_icon_description">Добавить событие</string>

  <!-- Card icon accessibility -->
  <string name="list_card_icon_description">Иконка %s</string>
  <string name="list_card_a11y_description">%1$s, %2$d дней до %3$s</string>
