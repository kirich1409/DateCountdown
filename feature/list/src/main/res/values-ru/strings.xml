  <plurals name="list_subtitle_events_ahead">
    <item quantity="one">%d событие впереди</item>
    <item quantity="few">%d события впереди</item>
    <item quantity="many">%d событий впереди</item>
    <item quantity="other">%d событий впереди</item>
  </plurals>
  <string name="list_subtitle_empty">Пока ничего не запланировано</string>

  <!-- Filter chips -->
  <string name="list_filter_all">Все</string>
  <string name="list_filter_soon">Скоро</string>
  <string name="list_filter_this_month">Этот месяц</string>
  <string name="list_filter_past">Прошедшие</string>

