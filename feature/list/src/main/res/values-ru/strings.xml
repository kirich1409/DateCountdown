  <plurals name="days_left">
    <item quantity="one">%d день осталось</item>
    <item quantity="few">%d дня осталось</item>
    <item quantity="many">%d дней осталось</item>
    <item quantity="other">%d дней осталось</item>
  </plurals>

  <!-- Past event card (issue #38) -->
  <string name="past_badge">ПРОШЛО</string>
  <string name="past_card_today_label">Сегодня</string>
